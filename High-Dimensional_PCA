#Experiment: High-Dimensional PCA

pca_hd = PCA()
pca_hd.fit(X_scaled)

explained_variance = pca_hd.explained_variance_ratio_

# Scree Plot
plt.figure(figsize=(7, 4))
plt.plot(np.cumsum(explained_variance), marker='o')
plt.xlabel("Number of Components")
plt.ylabel("Cumulative Explained Variance")
plt.title("Scree Plot – High-Dimensional PCA")
plt.show()

# Select components explaining 90% variance
num_components = np.argmax(np.cumsum(explained_variance) >= 0.90) + 1
print("Components explaining 90% variance:", num_components)
